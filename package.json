{
  "name": "crud-api",
  "version": "1.0.0",
  "description": "Simple crud api",
  "main": "index.js",
  "scripts": {
    "start:dev": "cross-env NODE_ENV=development nodemon",
    "dev": "cross-env NODE_ENV=development nodemon",
    "build": "tsc && node --loader ts-node/esm ./node_modules/webpack/bin/webpack.js --config webpack.config.ts",
    "start:prod": "npm run build && cross-env NODE_ENV=production node build/bundle.js",
    "test": "jest",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" --fix"
  },
  "author": "MikolaSh",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-typescript": "^7.27.1",
    "@types/clean-webpack-plugin": "^2.0.2",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.17.46",
    "@types/webpack": "^5.28.5",
    "@types/webpack-node-externals": "^3.0.4",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "clean-webpack-plugin": "^4.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.2.5",
    "ts-jest": "^29.3.2",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "webpack": "^5.99.8",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0"
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "dotenv": "^16.5.0",
    "uuid": "^11.1.0"
  }
}